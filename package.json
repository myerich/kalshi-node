{
  "name": "kalshi-node",
  "version": "2.0.0",
  "description": "TypeScript REST + WebSocket client for the Kalshi Trade API v2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client-base": {
      "types": "./dist/client-base.d.ts",
      "import": "./dist/client-base.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "e2e": "npm run test:e2e",
    "prepare": "npm run build",
    "test:panel": "concurrently \"npm run test:panel:server\" \"npm run test:panel:ui\"",
    "test:panel:server": "tsx tests/test-panel/server.ts",
    "test:panel:ui": "vite --config tests/test-panel/vite.config.ts",
    "panel": "npm run test:panel",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myerich/kalshi-node.git"
  },
  "keywords": [
    "kalshi",
    "prediction-market",
    "trading",
    "api-client",
    "websocket"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.4",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
